# Hugging Face token (for gated base models like Llama-3)
HF_TOKEN=your_hf_token_here

# vLLM OpenAI-compatible endpoint (set by serving/vllm_server.sh)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_NAME=medical-lora-13b
VLLM_API_KEY=local-dev-key

# Vector store
CHROMA_PERSIST_DIR=./chroma_data
VECTOR_COLLECTION=medical_kb

# FastAPI gateway
GATEWAY_API_KEY=replace_with_strong_key
LOG_LEVEL=INFO
RATE_LIMIT_PER_MIN=60

# Cloud (fill in when deploying)
AWS_REGION=us-east-1
GCP_PROJECT_ID=
